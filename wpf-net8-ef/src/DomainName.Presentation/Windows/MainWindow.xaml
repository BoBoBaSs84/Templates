<Window x:Class="DomainName.Presentation.Windows.MainWindow"
				xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				xmlns:vm="clr-namespace:DomainName.Application.ViewModels;assembly=DomainName.Application"
				mc:Ignorable="d"
				d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
				ShowInTaskbar="True"
				Title="{Binding ApplicationTitle}"
				Height="720"
				Width="1280"
				WindowStartupLocation="CenterScreen">
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
	</Window.Resources>
	<DockPanel>
		<!-- Menu Bar -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="_File">
				<MenuItem x:Name="NewMenuItem"
									Header="_New"
									InputGestureText="Ctrl+N"></MenuItem>
				<MenuItem x:Name="OpenMenuItem"
									Header="_Open"
									InputGestureText="Ctrl+O"></MenuItem>
				<Separator />
				<MenuItem x:Name="SettingsMenuItem"
									Header="_Settings"
									InputGestureText="Ctrl+S"
									Command="{Binding ShowSettingsCommand}"></MenuItem>
				<Separator />
				<MenuItem x:Name="ExitMenuItem"
									Header="_Exit"
									InputGestureText="Ctrl+X"
									Command="{Binding ExitApplicationCommand}"></MenuItem>
			</MenuItem>
			<MenuItem Header="_Help">
				<MenuItem x:Name="AboutMenuItem"
									Header="_About"
									InputGestureText="Ctrl+A"
									Command="{Binding ShowAboutCommand}"></MenuItem>
				<MenuItem x:Name="CheckForUpdatesMenuItem"
									Header="_Check for Updates..."
									InputGestureText="Ctrl+U"></MenuItem>
				<MenuItem x:Name="WhatsNewMenuItem"
									Header="_What's new..."></MenuItem>
				<Separator />
				<MenuItem x:Name="HelpMenuItem"
									Header="_Help"
									InputGestureText="Ctrl+H"></MenuItem>
			</MenuItem>
		</Menu>
		<!-- Status Bar -->
		<StatusBar DockPanel.Dock="Bottom">
			<StatusBarItem>
				<TextBlock Text="{Binding ApplicationStatus}" />
			</StatusBarItem>
			<StatusBarItem HorizontalAlignment="Right">
				<ProgressBar x:Name="mainProgressBar"
										 Width="200"
										 Height="16"
										 Minimum="{Binding ProgressBarMinimum}"
										 Maximum="{Binding ProgressBarMaximum}"
										 Value="{Binding ProgressBarValue}"
										 Visibility="{Binding ProgressBarVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
			</StatusBarItem>
		</StatusBar>
		<!-- Main Content Area -->
		<ContentControl Content="{Binding NavigationService.CurrentView}" />
	</DockPanel>
</Window>
