<UserControl x:Class="DomainName.Presentation.Controls.AboutControl"
						 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
						 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
						 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
						 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
						 xmlns:vm="clr-namespace:DomainName.Application.ViewModels;assembly=DomainName.Application"
						 d:DataContext="{d:DesignInstance Type=vm:AboutViewModel}"
						 mc:Ignorable="d"
						 d:Background="#F0F0F0"
						 d:Height="500"
						 d:Width="700">
	<UserControl.Resources>
		<Style x:Key="InfoLabel"
					 TargetType="TextBlock">
			<Setter Property="FontSize"
							Value="12" />
			<Setter Property="Foreground"
							Value="#888" />
			<Setter Property="Margin"
							Value="0,0,0,2" />
		</Style>
		<Style x:Key="InfoValue"
					 TargetType="TextBlock">
			<Setter Property="FontSize"
							Value="13" />
			<Setter Property="Foreground"
							Value="#222" />
			<Setter Property="Margin"
							Value="0,0,0,12" />
			<Setter Property="TextWrapping"
							Value="Wrap" />
		</Style>
	</UserControl.Resources>
	<Grid HorizontalAlignment="Center"
				VerticalAlignment="Center"
				MaxWidth="480">
		<!-- Card -->
		<Border Background="White"
						CornerRadius="6"
						Effect="{StaticResource CardShadow}">
			<DockPanel>
				<!-- Header banner -->
				<Border DockPanel.Dock="Top"
								Background="#1A1A2E"
								CornerRadius="6,6,0,0"
								Padding="28,24">
					<StackPanel HorizontalAlignment="Center">
						<Image x:Name="AboutIcon"
									 Source="/Resources/about.ico"
									 Width="48"
									 Height="48"
									 RenderOptions.BitmapScalingMode="HighQuality"
									 HorizontalAlignment="Center"
									 Margin="0,0,0,12" />
						<TextBlock Text="{Binding Title, Mode=OneWay}"
											 FontSize="22"
											 FontWeight="SemiBold"
											 Foreground="White"
											 HorizontalAlignment="Center" />
						<TextBlock FontSize="13"
											 Foreground="#AAB"
											 HorizontalAlignment="Center"
											 Margin="0,4,0,0">
							<Run Text="Version" />
							<Run Text="{Binding Version, Mode=OneWay}" /></TextBlock>
					</StackPanel>
				</Border>
				<!-- Body -->
				<StackPanel Margin="28,20,28,24">
					<!-- Description -->
					<TextBlock Text="{Binding Description, Mode=OneWay}"
										 Style="{StaticResource InfoValue}"
										 FontSize="13"
										 Foreground="#555"
										 TextAlignment="Center"
										 Margin="0,0,0,16" />
					<Separator Margin="0,0,0,16" />
					<!-- Info grid -->
					<TextBlock Text="COMPANY"
										 Style="{StaticResource InfoLabel}" />
					<TextBlock Text="{Binding Company, Mode=OneWay}"
										 Style="{StaticResource InfoValue}" />
					<TextBlock Text="COPYRIGHT"
										 Style="{StaticResource InfoLabel}" />
					<TextBlock Text="{Binding Copyright, Mode=OneWay}"
										 Style="{StaticResource InfoValue}" />
					<TextBlock Text="FRAMEWORK"
										 Style="{StaticResource InfoLabel}" />
					<TextBlock Text="{Binding FrameworkName, Mode=OneWay}"
										 Style="{StaticResource InfoValue}" />
					<TextBlock Text="REPOSITORY"
										 Style="{StaticResource InfoLabel}" />
					<TextBlock Margin="0,0,0,12">
						<Hyperlink NavigateUri="{Binding Repository}"
											 RequestNavigate="Hyperlink_RequestNavigate">
							<Run Text="{Binding Repository, Mode=OneWay}" />
						</Hyperlink></TextBlock>
				</StackPanel>
			</DockPanel>
		</Border>
	</Grid>
</UserControl>
